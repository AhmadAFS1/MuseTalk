# Copy this to .env.webrtc-turn.local and fill in the public TURN mapping.
# The local file is intentionally ignored by git because it contains TURN creds.

WEBRTC_RELAY_ENABLED=1
WEBRTC_TURN_AUTOSTART=1

# Public address/port that the browser can reach for the TURN listener.
# On Vast.ai, prefer the TCP-mapped internal port 1455 when available:
#   TURN_LISTEN_PORT=1455
#   TURN_PUBLIC_PORT=$VAST_TCP_PORT_1455
#   TURN_PUBLIC_TRANSPORT=tcp
# Fall back to UDP 3478 only if the client network and Vast UDP mapping are known-good.
TURN_PUBLIC_IP=CHANGE_ME_PUBLIC_IP
TURN_PUBLIC_PORT=CHANGE_ME_PUBLIC_PORT
TURN_PUBLIC_TRANSPORT=tcp

# Internal coturn listener used by the API process when WEBRTC_USE_LOCAL_TURN=1.
TURN_LISTEN_PORT=1455
WEBRTC_USE_LOCAL_TURN=1

TURN_USER=webrtc
TURN_PASS=CHANGE_ME_LONG_RANDOM_PASSWORD

WEBRTC_ICE_TRANSPORT_POLICY=relay
WEBRTC_STUN_URLS=
WEBRTC_SYNC_MODE=strict_fifo
WEBRTC_VIDEO_PREBUFFER_SECONDS=2.0
WEBRTC_AUDIO_PREBUFFER_SECONDS=0.0
WEBRTC_ADAPTIVE_FPS=0
