# Copy this to .env.webrtc-turn.local and fill in the public TURN mapping.
# The local file is intentionally ignored by git because it contains TURN creds.

WEBRTC_RELAY_ENABLED=1
WEBRTC_TURN_AUTOSTART=1

# Public address/port that the browser can reach for the TURN listener.
# On Vast.ai, prefer the TCP-mapped internal port 1455 when available:
#   TURN_LISTEN_PORT=1455
#   TURN_PUBLIC_PORT=$VAST_TCP_PORT_1455
#   TURN_PUBLIC_TRANSPORT=tcp
# Fall back to UDP 3478 only if the client network and Vast UDP mapping are known-good.
TURN_PUBLIC_IP=CHANGE_ME_PUBLIC_IP
TURN_PUBLIC_PORT=CHANGE_ME_PUBLIC_PORT
TURN_PUBLIC_TRANSPORT=tcp

# Internal coturn listener used by the API process when WEBRTC_USE_LOCAL_TURN=1.
TURN_LISTEN_PORT=1455
WEBRTC_USE_LOCAL_TURN=1

TURN_USER=webrtc
TURN_PASS=CHANGE_ME_LONG_RANDOM_PASSWORD

WEBRTC_ICE_TRANSPORT_POLICY=relay
WEBRTC_STUN_URLS=
WEBRTC_SYNC_MODE=strict_fifo
WEBRTC_VIDEO_PREBUFFER_SECONDS=2.0
WEBRTC_AUDIO_PREBUFFER_SECONDS=0.0
WEBRTC_ADAPTIVE_FPS=0

# Optional VAE INT8 8,16 serving profile. Uncomment when this worker should run
# the validated five-stage INT8 VAE decoder with batch-16 scheduler support.
# MUSETALK_VAE_BACKEND=trt_stagewise
# MUSETALK_TRT_STAGEWISE_PRECISION=int8_mixed
# MUSETALK_TRT_STAGEWISE_INT8_FRONTEND=onnx_qdq
# MUSETALK_TRT_STAGEWISE_INT8_STAGES=decoder_pre,decoder_mid_block,decoder_up_block_0,decoder_up_block_1,decoder_up_block_2
# MUSETALK_TRT_STAGEWISE_INT8_CALIBRATION_DIR=./calibration/vae_decoder
# MUSETALK_TRT_STAGEWISE_INT8_CACHE_DIR=./models/tensorrt/stagewise_int8_onnx_qdq_cache
# MUSETALK_TRT_STAGEWISE_WARMUP_BATCHES=8,16
# MUSETALK_TRT_FALLBACK=0
# HLS_SCHEDULER_MAX_BATCH=16
# HLS_SCHEDULER_FIXED_BATCH_SIZES=8,16

# Optional UNet capture for the next backend pass. Enable briefly during a
# representative WebRTC run, then validate with scripts/validate_unet_backend.py.
# MUSETALK_UNET_CALIBRATION_CAPTURE=1
# MUSETALK_UNET_CALIBRATION_DIR=./calibration/unet
# MUSETALK_UNET_CALIBRATION_MAX_BATCHES=64

# Optional UNet TensorRT runtime. Leave disabled until a UNet engine has passed
# scripts/validate_unet_backend.py on real capture files.
# MUSETALK_UNET_BACKEND=trt
# MUSETALK_TRT_UNET_ENABLED=1
# MUSETALK_TRT_UNET_PATH=./models/tensorrt/unet_trt.ts
# MUSETALK_TRT_UNET_META_PATH=./models/tensorrt/unet_trt_meta.json
